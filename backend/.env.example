# Database
DATABASE_URL=postgresql://hell:hell_password_change_me@postgres:5432/hell_manhwa?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT Secrets (at least 32 chars, change for production!)
JWT_ACCESS_SECRET=change_me_change_me_change_me_32chars
JWT_REFRESH_SECRET=change_me_refresh_me_change_me_32chars

# JWT Expiry
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Cookie Security (set true for HTTPS production)
COOKIE_SECURE=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# OTP
OTP_TTL_SECONDS=120
OTP_DEV_CODE=111111

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hell-manhwa
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_password_change_me
S3_FORCE_PATH_STYLE=true

# AI Bot (optional)
AI_BOT_ENABLED=true
AI_BASE_URL=https://api.freemodel.dev/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini